{
  "$schema": "https://opencode.ai/config.json",
  "theme": "ayu-dark",
  "model": "opencode-go/deepseek-v4-pro",
  "default_agent": "architect",
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 600000,
        "chunkTimeout": 60000
      }
    },
    "cline-pass": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ClinePass",
      "env": ["CLINE_API_KEY"],
      "options": {
        "baseURL": "https://api.cline.bot/api/v1",
        "headerTimeout": 60000,
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "glm-5.2": {
          "id": "cline-pass/glm-5.2",
          "name": "GLM-5.2",
          "limit": { "context": 1000000, "output": 131072 },
          "cost": { "input": 1.4, "output": 4.4, "cache_read": 0.26 }
        },
        "kimi-k2.7-code": {
          "id": "cline-pass/kimi-k2.7-code",
          "name": "Kimi K2.7 Code",
          "limit": { "context": 262144, "output": 262144 },
          "cost": { "input": 0.95, "output": 4.0, "cache_read": 0.19 }
        },
        "kimi-k2.6": {
          "id": "cline-pass/kimi-k2.6",
          "name": "Kimi K2.6",
          "limit": { "context": 262144, "output": 262144 },
          "cost": { "input": 0.95, "output": 4.0, "cache_read": 0.16 }
        },
        "deepseek-v4-pro": {
          "id": "cline-pass/deepseek-v4-pro",
          "name": "DeepSeek V4 Pro",
          "limit": { "context": 1000000, "output": 384000 },
          "cost": { "input": 1.74, "output": 3.48, "cache_read": 0.0145 }
        },
        "deepseek-v4-flash": {
          "id": "cline-pass/deepseek-v4-flash",
          "name": "DeepSeek V4 Flash",
          "limit": { "context": 1000000, "output": 384000 },
          "cost": { "input": 0.14, "output": 0.28, "cache_read": 0.0028 }
        },
        "mimo-v2.5": {
          "id": "cline-pass/mimo-v2.5",
          "name": "MiMo-V2.5",
          "limit": { "context": 1048576, "output": 131072 },
          "cost": { "input": 0.14, "output": 0.28, "cache_read": 0.0028 }
        },
        "mimo-v2.5-pro": {
          "id": "cline-pass/mimo-v2.5-pro",
          "name": "MiMo-V2.5-Pro",
          "limit": { "context": 1048576, "output": 131072 },
          "cost": { "input": 1.74, "output": 3.48, "cache_read": 0.0145 }
        },
        "minimax-m3": {
          "id": "cline-pass/minimax-m3",
          "name": "MiniMax M3",
          "limit": { "context": 512000, "output": 128000 },
          "cost": { "input": 0.3, "output": 1.2, "cache_read": 0.06 }
        },
        "qwen3.7-max": {
          "id": "cline-pass/qwen3.7-max",
          "name": "Qwen3.7 Max",
          "limit": { "context": 1000000, "output": 65536 },
          "cost": { "input": 2.5, "output": 7.5, "cache_read": 0.5, "cache_write": 3.125 }
        },
        "qwen3.7-plus": {
          "id": "cline-pass/qwen3.7-plus",
          "name": "Qwen3.7 Plus",
          "limit": { "context": 1000000, "output": 64000 },
          "cost": { "input": 0.4, "output": 1.6, "cache_read": 0.04, "cache_write": 0.5 }
        }
      }
    }
  },
  "agent": {
    "architect": {
      "color": "#3de070",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "build": {
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "plan": {
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "review": {
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "compaction": {
    "prune": true
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}
