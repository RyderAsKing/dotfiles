{
  "$schema": "https://opencode.ai/config.json",
  "theme": "ayu-dark",
  "model": "opencode-go/deepseek-v4-pro",
  "default_agent": "architect",
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 600000,
        "chunkTimeout": 60000
      }
    }
  },
  "agent": {
    "architect": {
      "model": "openai/gpt-5.5",
      "color": "#3de070",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "build": {
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "review": {
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "compaction": {
    "prune": true
  },
  "provider": {
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}
