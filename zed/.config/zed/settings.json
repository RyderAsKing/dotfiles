{
  "cli_default_open_behavior": "existing_window",
  "theme": "Tokyo Night",
  "base_keymap": "VSCode",

  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 18.0,

  "vim_mode": true,

  "icon_theme": "Zed (Default)",

  // Fonts
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "Ubuntu Sans",
  "buffer_font_size": 15,
  "buffer_line_height": {
    "custom": 1.7,
  },

  // Cursor
  "cursor_shape": "bar",
  "cursor_blink": false,

  // Editor
  "relative_line_numbers": "enabled",

  "scrollbar": {
    "show": "never",
  },

  // Terminal (FIXED)
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "dock": "left",
    "default_width": 360,
  },

  "inlay_hints": {
    "enabled": false,
  },

  // Edit predictions
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
  },

  // Agent
  "agent": {
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "OpenCode Go",
      "model": "minimax-m2.7",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "OpenCode Go",
      "model": "minimax-m2.7",
      "enable_thinking": false,
    },
    "sidebar_side": "left",
    "default_width": 360,
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },

  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "medium",
        "model": "gpt-5.5",
        "mode": "full-access",
      },
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },

  // Telemetry
  "language_models": {
    "openai_compatible": {
      "OpenCode Go": {
        "api_url": "https://opencode.ai/zen/go/v1",
        "available_models": [
          {
            "name": "minimax-m2.7",
            "max_tokens": 204800,
            "max_output_tokens": 131072,
            "max_completion_tokens": 204800,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
