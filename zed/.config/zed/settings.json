{
  "cli_default_open_behavior": "existing_window",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Carbonfox"
  },
  "base_keymap": "VSCode",

  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 18.0,

  "vim_mode": true,

  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },

  // Fonts
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "Ubuntu Sans",
  "buffer_font_size": 15,
  "buffer_line_height": {
    "custom": 1.7,
  },

  // Cursor
  "cursor_shape": "bar",
  "cursor_blink": false,

  // Editor
  "relative_line_numbers": "enabled",

  "scrollbar": {
    "show": "never",
  },

  // Keep all panels in a dock the same width when resizing or switching tabs.
  "resize_all_panels_in_dock": ["left", "right"],

  "project_panel": {
    "default_width": 300,
  },
  "outline_panel": {
    "default_width": 300,
  },
  "git_panel": {
    "default_width": 300,
  },
  "collaboration_panel": {
    "default_width": 300,
  },

  // Terminal (FIXED)
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "dock": "left",
    "default_width": 360,
  },

  "inlay_hints": {
    "enabled": false,
  },

  "lsp": {
    "luau-lsp": {
      "settings": {
        "roblox": {
          "enabled": true,
          "security_level": "roblox_script",
          "download_api_documentation": true,
          "download_definitions": true
        },
        "luau-lsp": {
          "sourcemap": {
            "enabled": true,
            "autogenerate": true,
            "rojoProjectFile": "default.project.json",
            "includeNonScripts": true,
            "sourcemapFile": "sourcemap.json"
          },
          "inlayHints": {
            "parameterNames": "all"
          }
        }
      }
    }
  },

  "languages": {
    "Luau": {
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["-"]
        }
      }
    },
  },

  // Edit predictions
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
  },

  // Agent
  "agent": {
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "OpenCode Go",
      "model": "minimax-m2.7",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "OpenCode Go",
      "model": "minimax-m2.7",
      "enable_thinking": false,
    },
    "sidebar_side": "left",
    "default_width": 360,
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },

  "agent_servers": {
  },

  // Telemetry
  "language_models": {
    "openai_compatible": {
      },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
