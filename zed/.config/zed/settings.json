{
  "vim_mode": true,

  "theme": "GitHub Dark Dimmed",
  "icon_theme": "Zed (Default)",

  // Font (NEW)
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15,
  "ui_font_size": 15,
  "buffer_font_weight": 400.0,
  "buffer_line_height": {
    "custom": 1.7,
  },

  "cursor_shape": "bar",
  "cursor_blink": false,

  "relative_line_numbers": "enabled",

  "scrollbar": {
    "show": "never",
  },

  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 15,
    "line_height": {
      "custom": 1.7,
    },
  },

  "inlay_hints": {
    "enabled": false,
  },

  "auto_indent_on_paste": true,
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
  },

  "cli_default_open_behavior": "new_window",

  "project_panel": {
    "default_width": 360.0,
    "dock": "right",
  },
  "outline_panel": {
    "default_width": 360.0,
    "dock": "right",
  },
  "collaboration_panel": {
    "default_width": 360.0,
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent": {
    "sidebar_side": "left",
    "default_width": 360.0,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },

  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
